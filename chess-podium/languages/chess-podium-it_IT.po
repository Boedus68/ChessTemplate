#: page-features.php
msgid "Tournament Management"
msgstr "Gestione tornei"

#: page-features.php
msgid "Create tournaments, add players, manage rounds and results—all in one intuitive panel."
msgstr "Crea tornei, aggiungi giocatori, gestisci turni e risultati in un unico pannello intuitivo."

#: page-features.php
msgid "Swiss & Round Robin"
msgstr "Svizzero e Round Robin"

#: page-features.php
msgid "Swiss pairing by score or Round Robin where everyone plays everyone. Configurable BYE points."
msgstr "Abbinamento svizzero per punteggio o Round Robin dove tutti giocano contro tutti. Punti BYE configurabili."

#: page-features.php
msgid "Public Pages"
